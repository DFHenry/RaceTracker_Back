<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Start Race</h1>

    <!-- Race Information -->
    <div id="raceInfo">
        <p>Number of Laps: <%= race.noOfLaps %></p>
        <p>Race is <%= race.raceState %></p>
        <p id="countdown"></p>
        <p id="stopWatch">00:00:00</p>
    </div>

    <h2>Laps</h2>
    <table>
        <thead>
            <th>Racer</th>
            <th>Vehicle</th>
            <th>Time</th>
            <th>Lap Number</th>
            <th>Pole Position</th>
        </thead>
        <tbody id="raceLaps">
            <tr>
                <!-- <td>Name</td>
                <td>Vehicle Number</td>
                <td>Time Index</td>
                <td>Lap Number</td>
                <td>Pole Position</td> -->
            </tr>
        </tbody>

    </table>

    <h2>Racers</h2>
    <table>
        <thead>
            <th>Racers</th>
            <th>Vehicle Number</th>
            <th>Vehicle Hex Code</th>
            <th>Actions</th>
        </thead>

        <tbody>
            <% race.racers.forEach(function(racer) { %>
            <tr>
                <td><%= racer.racerName %></td>
                <td><%= racer.vehicleNumber %></td>
                <td><%= racer.vehicleRFID %></td>
                <td><button>Remove Racer</button></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <div>
        <button id="startBtn">Start Race</button>
    </div>

    <form action="/stopRace">
        <button>Stop Race</button>
    </form>

    <!-- <p id="hiddenObject" style="display: none;"><%= race %></p> -->

    <script>
        //html elements
        let stopWatch = document.getElementById("stopWatch");
        let raceLaps = document.getElementById("raceLaps");
        let startBtn = document.getElementById("startBtn");

        var test = <%- JSON.stringify(race) %>;

        console.log(test);

        //timer variables
        let minutes = 0;
        let seconds = 0;
        let count = 0;

        //stopwatch display variables
        let dSecDisp = "";
        let secDisp = "";
        let minDisp = "";

        //timer boolean
        let timerOn = false;

        //active RFID Tags

        var activeTags = [];

        //websocket variables and functions
        const ws = new WebSocket('ws:localhost:8888');

        ws.onopen = () =>
        {
            console.log('connected to server: Race View');
            ws.send("initializeRace,0");
        }

        ws.onmessage = (event) =>
        {
            let temp = event.data;
            temp = temp.slice(0, -1);

            let dataArray = temp.split(",");

            //initization loop: gets all active vehicle's rfid hex codes and places them into an array
            if(dataArray[0] === "activeTags")
            {
                for(let i = 0; i < dataArray.length; i++)
                {
                    if(i === 0)
                    {
                    //ignore the first entry
                    }
                    else
                    {
                        activeTags.push(dataArray[i])
                    }
                }
            }

            else if(dataArray[0] === "detectedRFID")
            {
                for(let x = 0; x < activeTags.length; x++)
                {
                    if(activeTags[x] === dataArray[1])
                    {
                        

                        //display information
                        raceLaps.innerHTML +=  "<tr><td>Name</td><td>1</td><td>" + dataArray[2] + ":" + dataArray[3] + ":" + dataArray[4] + "</td><td>Lap 1/3</td><td>1st</td></tr>";
                        console.log("Lap Made By Tag " + dataArray[1] + " at time index " + dataArray[2] + ":" + dataArray[3] + ":" + dataArray[4]);
                    }
                }
            }
        }

        startBtn.onclick = startRace;

        //timer functions
        function startRace()
        {
            if(timerOn === false)
            {
                console.log("timer is on");
                startBtn.innerHTML = "Pause Race";
                timerOn = true;
            }
            else
            {
                console.log("timer is off");
                startBtn.innerHTML = "Resume Race";
                timerOn = false;
            }

            raceTimer();
        }

        function raceTimer()
        {
            //actual counter
            if(timerOn == true)
            {
                count++;
            }

            if(count == 100)
            {
                seconds += 1;
                count = 0;
            }
            if(seconds == 60)
            {
                minutes += 1;
                seconds = 0;
            }

            //counter display
            if(count < 10)
            {
                dSecDisp = "0" + count.toString();
            }
            else
            {
                dSecDisp = count.toString();
            }

            if(seconds < 10)
            {
                secDisp = "0" + seconds.toString();
            }
            else
            {
                secDisp = seconds.toString();
            }

            if(minutes < 10)
            {
                minDisp = "0" + minutes.toString();
            }
            else
            {
                minDisp = minutes.toString();
            }

            stopWatch.innerHTML = minDisp + ":" + secDisp + ":" + dSecDisp;

            if(timerOn == true)
            {
                ws.send("checkRFID" + "," + minDisp + "," + secDisp + "," + dSecDisp);
            }

            setTimeout(raceTimer, 10);
        }

    </script>
</body>

</html>