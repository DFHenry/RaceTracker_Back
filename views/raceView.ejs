<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <title>Race In Progress - David's RFID Race Tracking System</title>
</head>
<body>
<div class="container">
    <h1>Start Race</h1>

    <!-- Race Information -->
    <div id="raceInfo">
        <p>Number of Laps: <%= race.noOfLaps %></p>
        <p id="countdown">Countdown: 10</p>
        <p id="stopWatch">00:00:00</p>
    </div>

    <h2>Laps</h2>
    <table class="table table-striped">
        <thead>
            <th>Racer</th>
            <th>Vehicle</th>
            <th>Total Time</th>
            <th>Lap Time</th>
            <th>Lap Number</th>
            <th>Pole Position</th>
        </thead>
        <tbody id="raceLaps">
            <tr>
            </tr>
        </tbody>

    </table>

    <h2>Racers</h2>
    <table class="table table-striped table-sm">
        <thead>
            <th>Racers</th>
            <th>Vehicle Number</th>
            <th>Vehicle Hex Code</th>
            <th>Actions</th>
        </thead>

        <tbody>
            <% race.racers.forEach(function(racer) { %>
            <tr>
                <td><%- racer.racerName %></td>
                <td><%- racer.vehicleNumber %></td>
                <td><%- racer.vehicleRFID %></td>
                <td><button>Remove Racer</button></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <div>
        <button class="btn btn-info" id="startBtn">Start Race</button>
    </div>

    <form id="finishBtn" style="display: none;" action="/finishRace/submit" method="post">
        <input type="hidden" name="finishValue" id="finishValue" value="">
        <button class="btn btn-primary" type="submit">Finish Race</button>
    </form>
    <br>
    <form id="stopBtn" action="/stopRace/submit" method="post">
        <button class="btn btn-danger">Stop Race</button>
    </form>
</div>
    <script>
        //html elements
        let countDownDiv = document.getElementById("countdown");
        let stopWatch = document.getElementById("stopWatch");
        let raceLaps = document.getElementById("raceLaps");
        let startBtn = document.getElementById("startBtn");
        let stopBtn = document.getElementById("stopBtn");
        let finishValue = document.getElementById("finishValue");
        let finishBtn = document.getElementById("finishBtn");

        //race data from the DB
        const raceData = <%- JSON.stringify(race) %>;

        //timer variables
        let minutes = 0;
        let seconds = 0;
        let count = 0;
        let timerOn = false;

        //countdown integer
        let countDown = 10;

        //stopwatch display variables
        let dSecDisp = "";
        let secDisp = "";
        let minDisp = "";

        //lap records for racers
        var racerRecord;
        var lapRecord;
        var currentLap = 0;

        //single lap tracking
        var curLapCount = [];
        var curLapSec = [];
        var curLapMin = [];

        //lap object
        var lap = 
        {
            racerName: String,
            raceVehicle: Number,
            vehicleRFID: String,
            lapTime: String,
            singleLapTime: String,
            lapNumber: Number,
            polePosition: String,
            dateMade: String
        }

        //lap counter for each car
        var lapCounter = [];
        var lapInfo = [];

        //pole positions and ordinals
        var polePositions = [];
        let poleRecord = 0;
        var poleOrdinals = ["0th", "1st", "2nd", "3rd", "4th", "5th", "6th", "7th", "8th"];

        //post-race variables
        var newRaceRecord;

        //  +++ RACE INITIALIZATION +++

        //place records into the lapCounter and curLap arrays for each racer
        for(let i = 0; i < raceData.racers.length; i++)
        {
            lapCounter.push(0);
            curLapCount.push(0);
            curLapSec.push(0);
            curLapMin.push(0);
        }

        //websocket variables and functions
        const ws = new WebSocket('ws:localhost:8888');

        //event listeners
        ws.onopen = () =>
        {
            // console.log('connected to server: Race View');
        }

        //when receiving a message
        ws.onmessage = (event) =>
        {
            //parse the data from the message
            let temp = event.data;
            temp = temp.slice(0, -1);
            let dataArray = temp.split(",");

            //if the first string in dataArray is "detectedRFID", being lap and pole position updates
            if(dataArray[0] == "detectedRFID")
            {
                //lap information
                for(let x = 0; x < raceData.racers.length; x++)
                {
                    //if the data from the dataArray is equal to the vehicle RFID of a racer AND the lap data is less than the number laps in the race
                    if(raceData.racers[x].vehicleRFID == dataArray[1] && lapCounter[x] < raceData.noOfLaps)
                    {
                        //update lap information
                        lapCounter[x] += 1;
                        lapRecord = lapCounter[x];
                        racerRecord = raceData.racers[x];
                        addNewLap(dataArray);
                        break;
                    }
                    else
                    {
                        // console.log("Tag not valid for this race");
                    }
                }
            }
        }

        //event listener for starting a race
        startBtn.onclick = startRace;

        //timer functions
        function startRace()
        {
            //if the timer is not on
            if(timerOn === false)
            {
                //if the countdown has not hit zero, change the data appropriately, send the message to app.js and update the DB
                if(countDown > 1)
                {
                    countDown -= 1;
                    countDownDiv.innerHTML = "Countdown: " + countDown;
                    ws.send("startCountdown,_");
                    setTimeout(startRace, 1000);
                }
                //if the countdown has hit zero, start the race proper and race timer
                else
                {
                    countDownDiv.innerHTML = "Countdown: GO!";
                    startBtn.innerHTML = "Pause Race";
                    timerOn = true;
                    raceTimer();
                }

            }
            //if the timer is on - meant for pause button
            else
            {
                startBtn.innerHTML = "Resume Race";
                timerOn = false;
                raceTimer();
            }
        }

        //runs the minutes, seconds, and centiseconds (called count)
        function raceTimer()
        {
            //actual counter
            if(timerOn == true)
            {
                count++;
                for(let i = 0; i < raceData.racers.length; i++)
                {
                    curLapCount[i]++;
                }
            }

            //add a second if count hits 100, then reset count
            if(count == 100)
            {
                seconds += 1;
                count = 0;
                for(let i = 0; i < raceData.racers.length; i++)
                {
                    curLapSec[i] += 1;
                    curLapCount[i] = 0;
                }
            }

            //add one minute of seconds hits 60, then reset seconds
            if(seconds == 60)
            {
                minutes += 1;
                seconds = 0;
                for(let i = 0; i < raceData.racers.length; i++)
                {
                    curLapMin[i] += 1;
                    curLapSec[i] = 0;
                }
            }

            //counter display
            //if count is less than 10, change the display to add a 0 to the front of the display string, otherwise just use the count to display
            if(count < 10)
            {
                dSecDisp = "0" + count.toString();
            }
            else
            {
                dSecDisp = count.toString();
            }
            //if seconds is less than 10, change the display to add a 0 to the front of the display string, otherwise just use the seconds to display
            if(seconds < 10)
            {
                secDisp = "0" + seconds.toString();
            }
            else
            {
                secDisp = seconds.toString();
            }
            //if count is less than 10, change the display to add a 0 to the front of the display string, otherwise just use the minutes to display

            if(minutes < 10)
            {
                minDisp = "0" + minutes.toString();
            }
            else
            {
                minDisp = minutes.toString();
            }

            //display the timecode on the screen using the stopWatch element
            stopWatch.innerHTML = minDisp + ":" + secDisp + ":" + dSecDisp;

            //send a message to app.js to check if an RFID code has been placed into the rfid string
            if(timerOn == true)
            {
                ws.send("checkRFID" + "," + minDisp + "," + secDisp + "," + dSecDisp);
            }

            //repeat in 10 milliseconds (or one centisecond)
            setTimeout(raceTimer, 10);
        }

        //adds a new lap to the datta array
        function addNewLap(dataArray)
        {
            //update pole position information

            //if there are no laps currently recorded, add the new lap to the array
            if(polePositions.length == 0)
            {
                polePositions.push(dataArray[1]);

                poleRecord += 1;
            }
            //if pole positions has at least one entry in it
            else if(polePositions.length > 0)
            {
                let onPolePosition = false;

                //loop though the pole positions
                for(let y = 0; y < polePositions.length; y++)
                {
                    //if the pole position matches the rfid data, we know a racer has made an additional lap
                    if(polePositions[y] == dataArray[1])
                    {

                        onPolePosition = true;
                        break;
                    }
                    else
                    {
                        onPolePosition = false;
                    }
                }

                //if a racer has made a new lap after the first, clear the array and add the data back into the array
                if(onPolePosition == true)
                {
                    polePositions.length = 0;
                    polePositions.push(dataArray[1]);
                    poleRecord = 1;
                }
                //otherwise, push the lap data onto the array
                else
                {
                    polePositions.push(dataArray[1]);
                    poleRecord += 1;
                }
            }

            //create a new lap object and get the current date
            var newLap = Object.create(lap);
            var newDate = new Date();
            
            //fill in the newLap object with te appropriate data from the dataArray
            newLap.racerName = racerRecord.racerName;
            newLap.raceVehicle = racerRecord.vehicleNumber;
            newLap.vehicleRFID = dataArray[1];
            newLap.lapTime = dataArray[2] + ":" + dataArray[3] + ":" + dataArray[4];
            newLap.dateMade = newDate.getFullYear().toString() + "-" + newDate.getMonth().toString() + "-" + newDate.getDate().toString();
            
            //loop though the racers
            for(let i = 0; i < raceData.racers.length; i++)
            {
                //if the rfid matches one of the racers
                if(raceData.racers[i].vehicleNumber == racerRecord.vehicleNumber)
                {
                    //define variables for count, seconds and minutes to display
                    let tempLapCount = "";
                    let tempLapSec = "";
                    let tempLapMin = "";

                    //define the count into an appropriate string
                    if(curLapCount[i] < 10)
                    {
                        tempLapCount = "0" + curLapCount[i].toString();
                    }
                    else
                    {
                        tempLapCount = curLapCount[i].toString()
                    }

                    //define the seconds into an appropriate string
                    if(curLapSec[i] < 10)
                    {
                        tempLapSec = "0" + curLapSec[i].toString();
                    }
                    else
                    {
                        tempLapSec = curLapSec[i].toString();
                    }

                    //define the minutes into an appropriate string
                    if(curLapMin[i] < 10)
                    {
                        tempLapMin = "0" + curLapMin[i].toString();
                    }
                    else
                    {
                        tempLapMin = curLapMin[i].toString();
                    }

                    //define a string for the current race timestamp for display
                    newLap.singleLapTime = tempLapMin + ":" + tempLapSec + ":" + tempLapCount;

                    //reset the timestamp data
                    curLapCount[i] = 0;
                    curLapSec[i] = 0;
                    curLapMin[i] = 0;
                }
            }

            //define the lap numbers and pole positions
            newLap.lapNumber = lapRecord;
            newLap.polePosition = poleOrdinals[poleRecord];

            //push the lap into the lapInfo array
            lapInfo.push(newLap);

            //add the lap into the raceLaps table
            raceLaps.innerHTML += "<tr><td>" + racerRecord.racerName + "</td><td>" + racerRecord.vehicleNumber + "</td><td>" + dataArray[2] + ":" + dataArray[3] + ":" + dataArray[4] + "</td><td>" + newLap.singleLapTime + "</td><td>Lap " + lapRecord + "/" + raceData.noOfLaps + "</td><td>" + poleOrdinals[poleRecord] + "</td></tr>";

            //send message to app.js to add data to the DB
            ws.send("addNewLap" + "," + newLap.lapTime + "," + newLap.racerName + "," + newLap.lapNumber + "," + newLap.polePosition);

            //check if all racers have made all laps
            checkEnd();
        }

        //function to check if the race has ended
        async function checkEnd()
        {
            //define variables for the function 
            let endCondition = raceData.racers.length;
            let endCounter = 0;

            //loop though the lengtho of the lap counter
            for(let i = 0; i < lapCounter.length; i++)
            {
                //if the a racer has completed a number of laps equal to the number of laps in the race, add 1 to the endCounter
                if(lapCounter[i] == raceData.noOfLaps)
                {
                    endCounter += 1;
                }
            }

            //if the end counter is equal to the number of racers in the race, the race is over
            if(endCondition == endCounter)
            {
                //turn off the timer
                timerOn = false;

                //create a new record for the race
                var newRaceRecord = 
                {
                    raceDateTime: Date.now(),
                    noOfLaps: raceData.noOfLaps,
                    racers: raceData.racers,
                    lapRecords: lapInfo,
                    finalPositions: polePositions
                };

                //turn the data into a string to parse by app.js
                var raceRecordData = await JSON.stringify(newRaceRecord);

                //place the data into 
                finishValue.value = raceRecordData;

                //hide all other buttons, display the finish button
                startBtn.style.display = "none";
                stopBtn.style.display = "none";
                finishBtn.style.display = "block";
            }
            else
            {
                // console.log("Race Has Not Concluded");
            }
        }
    </script>
</body>

</html>