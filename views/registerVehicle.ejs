<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/2.0.4/socket.io.js"></script>
    <title>Register New Vehicle</title>
</head>
<body>
    <h1>Register New Vehicle</h1>

    <form action="/registerVehicle/submit" method="post">
        <label for="vehicleNumber">Vehicle Number: </label>
        <input type="number" name="vehicleNumber" id="vehicleNumber">
        <label for="tagHex">RFID Hex Code: </label>
        <input type="text" name="tagHex" id="tagHex">
        <input type="hidden" name="status" id="status" value="idle">
        <button type="submit">Add New Vehicle</button>
    </form>
    <p>Note: Scan a tag with the RFID to find the hex code of a new tag and refresh the page: It will be placed in the appropriate field automatically.</p>
    
    <form action="/dashboard">
        <button type="submit">Return to Dashboard</button>
    </form>
    
    <script>
        const tagHex = document.getElementById("tagHex");

        const ws = new WebSocket('ws:localhost:8888');

        ws.onopen = () =>
        {
            console.log("connected to server");
        }

        ws.onmessage = (event) =>
        {
            let temp = event.data
            temp = temp.slice(0,-1);

            let dataArray = temp.split(",");

            if(dataArray[0] === "detectedRFID")
            {
                tagHex.value = dataArray[1];
            }
        }

        setInterval(checkForRFID, 250);

        function checkForRFID()
        {
            ws.send("findRFID,ping");

            setTimeout(checkForRFID, 250);
        }
        
    </script>
</body>
</html>